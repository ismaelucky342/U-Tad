<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/saludo"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/descripcion"
        android:layout_marginTop="8dp"
        android:textSize="16sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/instruccion"
        android:layout_marginTop="4dp"
        android:textSize="14sp"
        android:alpha="0.7" />

    <TextView
        android:id="@+id/textoLocale"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textSize="14sp"
        android:fontFamily="monospace" />

    <Button
        android:id="@+id/botonOscuro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/boton_oscuro"
        android:layout_marginTop="32dp" />

    <Button
        android:id="@+id/botonClaro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/boton_claro"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/botonSistema"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/boton_sistema"
        android:layout_marginTop="8dp" />

</LinearLayout>
