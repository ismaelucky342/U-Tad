# ============================================================================
# AEC3 - Environment Variables Configuration
# Copia este archivo a .env y completa con tus credenciales
# ============================================================================

# ==================== TWITTER API (RapidAPI) ====================
# Obtén tu clave en: https://rapidapi.com/alexanderxbx/api/twitter-api45
RAPIDAPI_KEY=tu_clave_rapidapi_aqui

# ==================== LLM - OPCIÓN 1: Google Generative AI (Gemini) ====================
# Gratuita, sin límites estrictos
# Obtén tu clave en: https://aistudio.google.com
GOOGLE_API_KEY=tu_clave_google_ai_aqui

# ==================== LLM - OPCIÓN 2: OpenAI API ====================
# Requiere pago. Obtén clave en: https://platform.openai.com/api-keys
# OPENAI_API_KEY=tu_clave_openai_aqui

# ==================== Configuración de modelos locales ====================
# Si usas modelos de Hugging Face locales:
# - HF_HOME: Directorio donde se cachean los modelos descargados
# - HF_TOKEN: Token para acceder a modelos privados (opcional)
HF_HOME=./cache/huggingface
# HF_TOKEN=tu_token_huggingface_aqui

# ==================== Configuración de GPU ====================
# Para forzar CPU en lugar de GPU: USE_CPU=1
# Para usar GPU específica (CUDA): CUDA_VISIBLE_DEVICES=0
# USE_CPU=0
CUDA_VISIBLE_DEVICES=0

# ==================== Logging ====================
# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
