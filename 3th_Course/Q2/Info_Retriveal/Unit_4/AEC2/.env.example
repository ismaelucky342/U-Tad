# Twitter API via RapidAPI
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=twitter-api45.p.rapidapi.com

# Configuración opcional
# Número máximo de tweets a extraer en cada llamada
MAX_TWEETS_PER_REQUEST=100

# Número de tópicos para LDA (recomendado: 3-8)
NUM_LDA_TOPICS=5

# Proporción de oraciones para resumen extractivo (0.0-1.0)
SUMMARY_RATIO=0.05
